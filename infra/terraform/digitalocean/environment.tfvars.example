# Environment variables for Digital Ocean production infrastructure (dansysadm.com)
# Copy this file to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars with sensitive data!

region                      = "sfo1" # San Francisco 1 - West Coast US
droplet_size               = "s-1vcpu-2gb" # 1 vCPU, 2GB RAM
image                      = "debian-13-x64" # Debian 13 x64
ssh_key_id                 = "" # Leave empty if syncing from GitHub, otherwise use your DO SSH key ID
admin_ssh_ips              = ["YOUR_ADMIN_IP_1", "YOUR_ADMIN_IP_2"] # Replace with your IPs
kubernetes_client_ips      = ["YOUR_K8S_CLIENT_IP_1"] # Replace if using K8s
enable_floating_ip         = true
domain_name                = "dansysadm.com"

# Optional: Create managed Kubernetes cluster instead of single droplet
create_kubernetes_cluster  = false

# Sync SSH keys from GitHub daniellawrence account to DigitalOcean
sync_from_github           = false # Set to true to auto-sync your GitHub SSH keys to DO
